{
  "name": "tick",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:vite": "vite",
    "dev:pages": "wrangler pages dev --proxy 5173 --port 8788 --d1=DB",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:pages\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:init": "wrangler d1 execute tick --local --file=migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute tick --file=migrations/0001_init.sql",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260616.1",
    "@hono/zod-validator": "^0.8.0",
    "bad-words": "^4.0.0",
    "concurrently": "^10.0.3",
    "hono": "^4.12.25",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wrangler": "^4.100.0"
  }
}
